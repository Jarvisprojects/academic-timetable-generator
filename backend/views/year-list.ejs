<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>Years - Timetable Scheduler</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-slate-100">
    <nav class="bg-white shadow-sm border-b border-slate-200 no-print">...</nav>
    <main class="max-w-4xl mx-auto px-4 py-8">
        <h1 class="text-2xl font-bold">
            <%= timetable.name %>
        </h1>
        <p class="text-slate-500 mb-4">
            <%= timetable.description || '' %>
        </p>
        <h2 class="text-xl font-semibold mb-2">Select a Year</h2>
        <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
            <% years.forEach(y=>{ %><a href="/year-grid?id=<%= timetable.id %>&year=<%= encodeURIComponent(y) %>"
                    class="block p-4 bg-white rounded shadow hover:bg-blue-50 transition">
                    <div class="font-bold">
                        <%= y %>
                    </div>
                </a>
                <% }); %>
        </div>
        <div class="mt-6"><a href="/grid?id=<%= timetable.id %>" class="text-blue-600">← Back to Full Timetable</a>
        </div>
    </main>
    <script src="/js/api.js"></script>
    <script>(async () => { try { const u = await checkAuth(); document.getElementById('username').textContent = `Hello, ${u.username}`; } catch (e) { } })();</script>
</body>

</html>