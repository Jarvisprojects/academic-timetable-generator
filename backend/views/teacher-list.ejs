<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Teachers - Timetable Scheduler</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>
<body class="bg-slate-100 font-sans">
    <nav class="bg-white shadow-sm border-b border-slate-200 no-print">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between items-center h-16">
                <a href="/" class="text-xl font-bold text-blue-600">Timetable Scheduler</a>
                <div class="flex items-center gap-4">
                    <span id="username" class="text-sm text-slate-600"></span>
                    <button type="button" onclick="event.preventDefault(); logout();" class="text-sm text-red-600 hover:text-red-800">Logout</button>
                    <a href="/dashboard" class="text-sm text-slate-600 hover:text-slate-800">← Back</a>
                </div>
            </div>
        </div>
    </nav>
    <main class="max-w-4xl mx-auto px-4 py-8">
        <h1 class="text-2xl font-bold"><%= timetable.name %></h1>
        <p class="text-slate-500 mb-4"><%= timetable.description || '' %></p>
        <h2 class="text-xl font-semibold mb-2">Select a Teacher</h2>
        <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
            <% teachers.forEach(t => { %>
                <a href="/teacher-grid?id=<%= timetable.id %>&teacher=<%= encodeURIComponent(t) %>"
                   class="block p-4 bg-white rounded shadow hover:bg-blue-50 transition">
                    <div class="font-bold"><%= t %></div>
                </a>
            <% }); %>
        </div>
        <div class="mt-6"><a href="/grid?id=<%= timetable.id %>" class="text-blue-600">← Back to Full Timetable</a></div>
    </main>
    <script src="/js/api.js"></script>
    <script>
        (async () => {
            try {
                const user = await checkAuth();
                document.getElementById('username').textContent = `Hello, ${user.username}`;
            } catch(e) {}
        })();
    </script>
</body>
</html>