<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Dashboard | Timetable Scheduler</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <style>
      body {
        font-family: "Plus Jakarta Sans", sans-serif;
        background: #f1f5f9;
      }
      .stat-card {
        transition: all 0.25s cubic-bezier(0.2, 0, 0, 1);
        backdrop-filter: blur(0px);
      }
      .stat-card:hover {
        transform: translateY(-3px);
        box-shadow: 0 20px 30px -12px rgba(0, 0, 0, 0.12);
      }
      .custom-scrollbar::-webkit-scrollbar {
        height: 5px;
        width: 5px;
      }
      .custom-scrollbar::-webkit-scrollbar-track {
        background: #eef2ff;
        border-radius: 20px;
      }
      .custom-scrollbar::-webkit-scrollbar-thumb {
        background: #b9c3da;
        border-radius: 20px;
      }
      .glass-nav {
        background: rgba(255, 255, 255, 0.85);
        backdrop-filter: blur(12px);
      }
      .table-row-hover {
        transition: all 0.2s;
      }
      .badge-glow {
        box-shadow: 0 0 0 1px rgba(255, 255, 255, 0.3);
      }
      .draft-card {
        background: linear-gradient(105deg, #fff 0%, #fef9e6 100%);
        border-left: 5px solid #f59e0b;
      }
    </style>
  </head>
  <body class="text-slate-800 antialiased">
    <!-- Navigation (refined glass effect) -->
    <nav
      class="glass-nav shadow-sm sticky top-0 z-50 border-b border-slate-200/70"
    >
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between items-center h-16">
          <a href="/" class="flex items-center gap-3 group">
            <div
              class="w-9 h-9 bg-gradient-to-tr from-indigo-600 to-blue-600 rounded-xl flex items-center justify-center shadow-md shadow-indigo-200 group-hover:scale-105 transition-transform duration-200"
            >
              <svg
                class="w-5 h-5 text-white"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"
                />
              </svg>
            </div>
            <span
              class="text-xl font-extrabold tracking-tight bg-gradient-to-r from-slate-800 to-slate-600 bg-clip-text text-transparent"
              >Timetable Generator</span
            >
          </a>
          <div class="flex items-center gap-5">
            <span
              id="username"
              class="text-sm font-semibold text-slate-600 bg-slate-100/80 px-3 py-1.5 rounded-full hidden sm:block"
            ></span>
            <button
              type="button"
              onclick="event.preventDefault(); logout();"
              class="text-sm font-bold text-rose-500 hover:text-rose-700 transition-colors tracking-wide"
            >
              Logout
            </button>
          </div>
        </div>
      </div>
    </nav>

    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 md:py-10">
      <!-- Header Section: refined -->
      <div
        class="flex flex-col md:flex-row justify-between items-start md:items-end gap-5 mb-8"
      >
        <div>
          <h1
            class="text-3xl md:text-4xl font-black text-slate-800 tracking-tight"
          >
            Dashboard
          </h1>
          <p
            class="text-slate-500 font-medium mt-1.5 flex items-center gap-1.5"
          >
            <span class="w-1.5 h-1.5 bg-emerald-400 rounded-full"></span>
            Institutional planning & resource hub
          </p>
        </div>
        <a
          href="/new"
          class="w-full md:w-auto inline-flex items-center justify-center gap-2 px-6 py-3 bg-gradient-to-r from-indigo-600 to-blue-600 text-white font-extrabold rounded-xl shadow-lg shadow-indigo-200 hover:shadow-indigo-300 hover:scale-[1.01] active:scale-95 transition-all duration-200 text-sm tracking-wide"
        >
          <svg
            class="w-4 h-4"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2.5"
              d="M12 4v16m8-8H4"
            />
          </svg>
          Create Timetable
        </a>
      </div>

      <!-- Draft Card (no changes to logic) -->
      <div
        id="draft-card"
        class="hidden mb-8 draft-card rounded-2xl shadow-sm p-5 border border-amber-200/80"
      >
        <div class="flex flex-wrap justify-between items-center gap-4">
          <div class="flex-1">
            <div class="flex items-center gap-2">
              <span
                class="text-xs font-black text-amber-700 uppercase tracking-wider bg-amber-100 px-2 py-0.5 rounded-full"
                >Draft saved</span
              >
            </div>
            <p
              id="draft-name"
              class="text-lg font-bold text-slate-800 mt-1.5"
            ></p>
            <p
              id="draft-desc"
              class="text-slate-500 text-sm mt-0.5 line-clamp-1"
            ></p>
          </div>
          <div class="flex gap-3">
            <a
              href="/new?draft=1"
              class="px-5 py-2 bg-amber-500 text-white rounded-xl font-bold text-sm hover:bg-amber-600 transition shadow-sm"
              >✏️ Resume Draft</a
            >
            <button
              id="delete-draft-btn"
              class="px-5 py-2 bg-white border border-slate-200 text-slate-600 rounded-xl font-bold text-sm hover:bg-slate-50 hover:text-red-600 transition"
            >
              🗑️ Delete
            </button>
          </div>
        </div>
      </div>

      <!-- STATS SECTION: PROCESSING CARD FULLY REMOVED -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 mb-10">
        <!-- Total Projects Card -->
        <div
          class="stat-card bg-white rounded-2xl p-6 border border-slate-100 shadow-sm hover:shadow-md"
        >
          <div class="flex items-center justify-between mb-3">
            <div
              class="w-11 h-11 bg-indigo-50 text-indigo-600 rounded-xl flex items-center justify-center"
            >
              <svg
                class="w-6 h-6"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"
                />
              </svg>
            </div>
            <span class="text-3xl font-black text-slate-800" id="stat-total"
              >—</span
            >
          </div>
          <p class="text-slate-500 text-xs font-bold uppercase tracking-wider">
            Total schedules
          </p>
          <p class="text-[11px] text-slate-400 font-medium mt-1">
            All created timetables
          </p>
        </div>

        <!-- Successful Card -->
        <div
          class="stat-card bg-white rounded-2xl p-6 border border-slate-100 shadow-sm hover:shadow-md"
        >
          <div class="flex items-center justify-between mb-3">
            <div
              class="w-11 h-11 bg-emerald-50 text-emerald-600 rounded-xl flex items-center justify-center"
            >
              <svg
                class="w-6 h-6"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"
                />
              </svg>
            </div>
            <span class="text-3xl font-black text-slate-800" id="stat-success"
              >—</span
            >
          </div>
          <p class="text-slate-500 text-xs font-bold uppercase tracking-wider">
            Completed
          </p>
          <p class="text-[11px] text-slate-400 font-medium mt-1">
            Ready & published
          </p>
        </div>

        <!-- Failed Card (renamed elegantly) -->
        <div
          class="stat-card bg-white rounded-2xl p-6 border border-slate-100 shadow-sm hover:shadow-md"
        >
          <div class="flex items-center justify-between mb-3">
            <div
              class="w-11 h-11 bg-rose-50 text-rose-500 rounded-xl flex items-center justify-center"
            >
              <svg
                class="w-6 h-6"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
                />
              </svg>
            </div>
            <span class="text-3xl font-black text-slate-800" id="stat-failed"
              >—</span
            >
          </div>
          <p class="text-slate-500 text-xs font-bold uppercase tracking-wider">
            Issues
          </p>
          <p class="text-[11px] text-slate-400 font-medium mt-1">
            Requires attention
          </p>
        </div>
      </div>

      <!-- Timetable Table - redesigned with clean aesthetics -->
      <div
        class="bg-white rounded-2xl shadow-sm border border-slate-200/80 overflow-hidden"
      >
        <div
          class="px-6 md:px-8 py-5 border-b border-slate-100 flex flex-wrap justify-between items-center gap-3 bg-white/40"
        >
          <div>
            <h2
              class="text-xl font-extrabold text-slate-800 tracking-tight flex items-center gap-2"
            >
              📋 Timetable library
              <span
                class="bg-slate-100 text-slate-500 text-[10px] font-black px-2 py-0.5 rounded-full"
                >Recent</span
              >
            </h2>
            <p class="text-xs text-slate-400 font-medium mt-0.5">
              Manage, preview or archive schedules
            </p>
          </div>
          <div
            class="text-xs text-slate-400 bg-slate-50 px-3 py-1.5 rounded-full font-medium"
          >
            auto‑sync active
          </div>
        </div>
        <div class="overflow-x-auto custom-scrollbar">
          <table class="min-w-full divide-y divide-slate-100">
            <thead class="bg-slate-50/60">
              <tr>
                <th
                  class="px-6 md:px-8 py-4 text-left text-[11px] font-black text-slate-400 uppercase tracking-wider"
                >
                  Name
                </th>
                <th
                  class="px-6 md:px-8 py-4 text-left text-[11px] font-black text-slate-400 uppercase tracking-wider"
                >
                  Description
                </th>
                <th
                  class="px-6 md:px-8 py-4 text-left text-[11px] font-black text-slate-400 uppercase tracking-wider"
                >
                  Status
                </th>
                <th
                  class="px-6 md:px-8 py-4 text-left text-[11px] font-black text-slate-400 uppercase tracking-wider"
                >
                  Created
                </th>
                <th
                  class="px-6 md:px-8 py-4 text-right text-[11px] font-black text-slate-400 uppercase tracking-wider"
                >
                  Actions
                </th>
              </tr>
            </thead>
            <tbody
              id="timetables-tbody"
              class="bg-white divide-y divide-slate-50"
            >
              <tr>
                <td colspan="5" class="px-6 py-20 text-center">
                  <div class="flex flex-col items-center gap-3">
                    <div
                      class="w-10 h-10 border-3 border-indigo-200 border-t-indigo-600 rounded-full animate-spin"
                    ></div>
                    <p class="text-slate-400 font-semibold text-sm">
                      Loading schedules...
                    </p>
                  </div>
                </td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </main>

    <script src="/js/api.js"></script>
    <script>
      let user = null;

      // Helper: consistent toast
      function toast(msg, type) {
        const toastDiv = document.createElement("div");
        const bgColor = type === "success" ? "bg-emerald-600" : "bg-rose-600";
        toastDiv.className = `fixed bottom-6 right-6 z-[70] px-5 py-3 rounded-xl shadow-2xl text-white font-bold text-sm ${bgColor} transition-all duration-300 flex items-center gap-2`;
        toastDiv.innerHTML = `<span>${type === "success" ? "✓" : "⚠️"}</span> ${msg}`;
        document.body.appendChild(toastDiv);
        setTimeout(() => {
          toastDiv.style.opacity = "0";
          toastDiv.style.transform = "translateY(10px)";
          setTimeout(() => toastDiv.remove(), 250);
        }, 2800);
      }

      // Authentication and admin panel injection
      (async () => {
        try {
          user = await checkAuth();
          const usernameSpan = document.getElementById("username");
          if (usernameSpan) usernameSpan.textContent = `👋 ${user.username}`;
          if (user.is_admin) {
            const navDiv = document.querySelector(
              "nav .flex.items-center.gap-5",
            );
            if (navDiv) {
              const adminLink = document.createElement("a");
              adminLink.href = "/admin";
              adminLink.className =
                "text-sm font-bold text-indigo-600 hover:text-indigo-800 transition-colors tracking-wide bg-indigo-50/60 px-3 py-1.5 rounded-full";
              adminLink.textContent = "⚙️ Admin";
              navDiv.insertBefore(adminLink, navDiv.lastElementChild);
            }
          }
          await loadTimetables();
          loadDraft();
        } catch (e) {
          console.warn("Auth error handled by apiFetch");
        }
      })();

      // Load timetables and update stats (Processing card removed => no pending stat)
      async function loadTimetables() {
        try {
          const timetables = await apiFetch("/api/timetables");
          const total = timetables.length;
          const success = timetables.filter(
            (tt) => tt.status === "success",
          ).length;
          const failed = timetables.filter(
            (tt) => tt.status === "failed",
          ).length;
          // pending count is intentionally ignored (no UI element)

          // update stats fields (only 3 cards)
          document.getElementById("stat-total").textContent = total;
          document.getElementById("stat-success").textContent = success;
          document.getElementById("stat-failed").textContent = failed;

          const tbody = document.getElementById("timetables-tbody");
          if (timetables.length === 0) {
            tbody.innerHTML = `
                        <tr>
                            <td colspan="5" class="px-6 py-16 text-center">
                                <div class="flex flex-col items-center gap-2">
                                    <div class="bg-slate-100 rounded-full p-3">
                                        <svg class="w-8 h-8 text-slate-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg>
                                    </div>
                                    <p class="text-slate-400 font-medium">No timetables yet</p>
                                    <a href="/new" class="text-indigo-600 font-bold hover:underline text-sm mt-1">Create your first timetable →</a>
                                </div>
                            </td>
                        </tr>
                    `;
            return;
          }

          tbody.innerHTML = timetables
            .slice(0, 12)
            .map((tt) => {
              let statusBadge = "";
              if (tt.status === "pending") {
                statusBadge = `<span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-[11px] font-black uppercase tracking-wider bg-amber-50 text-amber-700 border border-amber-200"><span class="w-1.5 h-1.5 bg-amber-500 rounded-full animate-pulse"></span>Processing</span>`;
              } else if (tt.status === "success") {
                statusBadge = `<span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-[11px] font-black uppercase tracking-wider bg-emerald-50 text-emerald-700 border border-emerald-200"><span class="w-1.5 h-1.5 bg-emerald-500 rounded-full"></span>Completed</span>`;
              } else {
                statusBadge = `<span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-[11px] font-black uppercase tracking-wider bg-rose-50 text-rose-700 border border-rose-200"><span class="w-1.5 h-1.5 bg-rose-500 rounded-full"></span>Failed</span>`;
              }

              let actionButtons = "";
              // Always show copy JSON and delete
              actionButtons += `<button onclick="copyJSON(${tt.id})" class="p-1.5 hover:bg-indigo-50 text-indigo-600 rounded-lg transition-colors font-bold text-[11px] uppercase tracking-wide">Copy JSON</button>`;
              if (tt.status === "success") {
                actionButtons += `<a href="/view?id=${tt.id}" class="p-1.5 hover:bg-indigo-50 text-indigo-600 rounded-lg transition-colors font-bold text-[11px] uppercase tracking-wide">JSON</a>`;
                actionButtons += `<a href="/grid?id=${tt.id}" class="p-1.5 hover:bg-emerald-50 text-emerald-600 rounded-lg transition-colors font-bold text-[11px] uppercase tracking-wide">Grid</a>`;
              }
              if (tt.status === "pending") {
                actionButtons += `<a href="/processing?id=${tt.id}" class="p-1.5 hover:bg-amber-50 text-amber-600 rounded-lg transition-colors font-bold text-[11px] uppercase tracking-wide">Monitor</a>`;
              }
              actionButtons += `<button onclick="deleteTimetable(${tt.id})" class="p-1.5 hover:bg-rose-50 text-rose-600 rounded-lg transition-colors font-bold text-[11px] uppercase tracking-wide">Delete</button>`;

              return `
                        <tr class="hover:bg-slate-50/70 transition-all duration-150 group">
                            <td class="px-6 md:px-8 py-4 font-bold text-slate-800 text-sm">${escapeHtml(tt.name)}</td>
                            <td class="px-6 md:px-8 py-4 text-slate-500 text-sm font-medium max-w-xs truncate">${escapeHtml(tt.description || "—")}</td>
                            <td class="px-6 md:px-8 py-4">${statusBadge}</td>
                            <td class="px-6 md:px-8 py-4 text-sm text-slate-400 font-medium">${new Date(tt.created_at).toLocaleDateString(undefined, { month: "short", day: "numeric", year: "numeric" })}</td>
                            <td class="px-6 md:px-8 py-4 text-right">
                                <div class="flex justify-end gap-2 opacity-0 group-hover:opacity-100 transition-opacity duration-200 flex-wrap">${actionButtons}</div>
                            </td>
                        </tr>
                    `;
            })
            .join("");
        } catch (err) {
          console.error("Failed to load timetables", err);
          const tbody = document.getElementById("timetables-tbody");
          if (tbody)
            tbody.innerHTML = `<tr><td colspan="5" class="px-6 py-10 text-center text-rose-500 font-medium">⚠️ Failed to load timetables. Refresh?</td></tr>`;
        }
      }

      // Delete timetable with confirmation (unchanged logic)
      async function deleteTimetable(id) {
        if (
          !confirm(
            "Delete this timetable permanently? This action cannot be undone.",
          )
        )
          return;
        try {
          await apiFetch(`/api/timetables/${id}`, { method: "DELETE" });
          await loadTimetables();
          toast("Timetable deleted", "success");
        } catch (err) {
          toast(err.message || "Deletion failed", "error");
        }
      }

      // Copy JSON to clipboard
      async function copyJSON(id) {
        try {
          const res = await fetch(`/api/timetables/${id}/download/input`, {
            headers: {
              Authorization: `Bearer ${localStorage.getItem("token")}`,
            },
          });
          if (!res.ok) throw new Error("Failed to fetch JSON");
          const json = await res.json();
          await navigator.clipboard.writeText(JSON.stringify(json, null, 2));
          toast("Input JSON copied to clipboard!", "success");
        } catch (err) {
          toast("Could not copy JSON", "error");
        }
      }

      // Draft card handler (fully functional, no changes to logic)
      function loadDraft() {
        const draftRaw = localStorage.getItem("timetable_draft");
        if (!draftRaw) return;
        try {
          const draft = JSON.parse(draftRaw);
          const draftCard = document.getElementById("draft-card");
          if (!draftCard) return;
          document.getElementById("draft-name").textContent =
            draft.name || "Untitled draft";
          document.getElementById("draft-desc").textContent =
            draft.description || "Click to continue editing";
          draftCard.classList.remove("hidden");

          const deleteBtn = document.getElementById("delete-draft-btn");
          if (deleteBtn) {
            deleteBtn.onclick = () => {
              if (confirm("Remove this draft? It will be lost permanently.")) {
                localStorage.removeItem("timetable_draft");
                draftCard.classList.add("hidden");
                toast("Draft discarded", "success");
              }
            };
          }
        } catch (e) {
          console.error("Invalid draft", e);
          localStorage.removeItem("timetable_draft");
        }
      }

      // Helper: escape HTML
      function escapeHtml(str) {
        if (!str) return str;
        return str.replace(/[&<>]/g, (m) =>
          m === "&" ? "&amp;" : m === "<" ? "&lt;" : "&gt;",
        );
      }

      // Logout is exposed globally from api.js - use that instead
      // window.logout is already defined there

      // Expose functions to global scope
      window.deleteTimetable = deleteTimetable;
      window.copyJSON = copyJSON;
    </script>
  </body>
</html>
