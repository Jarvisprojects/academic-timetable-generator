<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Teacher: <%= teacher %> - Timetable</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        .timetable-cell {
            border: 1px solid #e2e8f0;
            padding: 0.5rem;
            vertical-align: top;
            min-width: 120px;
        }
        .timetable-time {
            background-color: #f8fafc;
            font-weight: 500;
        }
        .event-item {
            background-color: #f0f9ff;
            border-left: 4px solid #3b82f6;
            margin-bottom: 0.25rem;
            padding: 0.25rem;
            font-size: 0.75rem;
            border-radius: 0.25rem;
        }
        .year-section {
            margin-bottom: 2rem;
            break-inside: avoid;
        }
        @media print {
            body { background: white; }
            .no-print { display: none; }
            .timetable-cell { border: 1px solid #ccc; }
        }
    </style>
</head>
<body class="bg-slate-100">
    <nav class="bg-white shadow-sm border-b border-slate-200 no-print">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between items-center h-16">
                <a href="/" class="text-xl font-bold text-blue-600">Timetable Scheduler</a>
                <div class="flex items-center gap-4">
                    <span id="username" class="text-sm text-slate-600"></span>
                    <button onclick="logout()" class="text-sm text-red-600 hover:text-red-800">Logout</button>
                    <button onclick="window.print()" class="text-sm bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700">Print</button>
                    <button id="export-csv" class="text-sm bg-green-600 text-white px-4 py-2 rounded hover:bg-green-700">Export CSV</button>
                    <a href="/teacher-grid?id=<%= timetable.id %>" class="text-sm bg-purple-600 text-white px-4 py-2 rounded hover:bg-purple-700">All Teachers</a>
                    <a href="/grid?id=<%= timetable.id %>" class="text-sm text-slate-600 hover:text-slate-800">← Main Grid</a>
                </div>
            </div>
        </div>
    </nav>

    <main class="max-w-7xl mx-auto px-4 py-8">
        <div>
            <h1 class="text-2xl font-bold">Teacher: <%= teacher %></h1>
            <p class="text-slate-500"><%= timetable.name %></p>
        </div>

        <%
            const dayNames = ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday', 'Sunday'].slice(0, daysCount);
            // Group events by year
            const eventsByYear = {};
            events.forEach(ev => {
                if (!eventsByYear[ev.year]) eventsByYear[ev.year] = [];
                eventsByYear[ev.year].push(ev);
            });
        %>

        <% for (const year in eventsByYear) { 
            const yearEvents = eventsByYear[year];
            const slots = slotMapping[year];
            if (!slots) continue;
            const slotList = Object.entries(slots).sort((a,b) => parseInt(a[0]) - parseInt(b[0]));
            // Build grid for this year
            const grid = {};
            slotList.forEach(([slotIdx]) => {
                grid[slotIdx] = {};
                for (let d = 0; d < daysCount; d++) grid[slotIdx][d] = [];
            });
            yearEvents.forEach(ev => {
                for (let s = ev.start_slot; s <= ev.end_slot; s++) {
                    if (grid[s] && grid[s][ev.day]) grid[s][ev.day].push(ev);
                }
            });
        %>
            <div class="year-section mt-8">
                <h2 class="text-xl font-bold mb-2"><%= year %></h2>
                <div class="overflow-x-auto bg-white rounded shadow">
                    <table class="min-w-full border-collapse">
                        <thead>
                            <tr class="bg-slate-50">
                                <th class="border p-2">Time</th>
                                <% for (let i = 0; i < daysCount; i++) { %>
                                    <th class="border p-2"><%= dayNames[i] %></th>
                                <% } %>
                              </tr>
                        </thead>
                        <tbody>
                            <% slotList.forEach(([slotIdx, timeRange]) => { %>
                                <tr>
                                    <td class="border p-2 font-medium"><%= timeRange[0] %> – <%= timeRange[1] %></td>
                                    <% for (let d = 0; d < daysCount; d++) { %>
                                        <td class="border p-2 align-top">
                                            <% const evs = grid[slotIdx][d]; if (evs && evs.length) {
                                                evs.forEach(ev => { %>
                                                    <div class="event-item">
                                                        <div class="font-semibold"><%= ev.subject %></div>
                                                        <div class="text-xs"><%= ev.type === 'lecture' ? 'Lecture' : 'Practical' %></div>
                                                        <% if (ev.type === 'practical') { %>
                                                            <div class="text-xs">Lab: <%= ev.lab %></div>
                                                            <div class="text-xs">Batch: <%= ev.batch %></div>
                                                        <% } else { %>
                                                            <div class="text-xs">Room: <%= ev.room %></div>
                                                        <% } %>
                                                    </div>
                                                <% });
                                            } else { %>
                                                <span class="text-slate-300 text-xs">—</span>
                                            <% } %>
                                        </td>
                                    <% } %>
                                </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>
            </div>
        <% } %>

        <% if (Object.keys(eventsByYear).length === 0) { %>
            <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-6 text-center mt-8">
                <p class="text-yellow-800">No events found for this teacher.</p>
            </div>
        <% } %>
    </main>

    <script src="/js/api.js"></script>
    <script>
        (async () => {
            try {
                const user = await checkAuth();
                document.getElementById('username').textContent = `Hello, ${user.username}`;
            } catch(e) {}
        })();

        document.getElementById('export-csv').addEventListener('click', () => {
            let csv = '';
            const tables = document.querySelectorAll('table');
            tables.forEach(table => {
                const rows = table.querySelectorAll('tbody tr');
                rows.forEach(row => {
                    const rowData = [];
                    row.querySelectorAll('td').forEach(cell => {
                        const events = cell.querySelectorAll('.event-item');
                        let content = '';
                        if (events.length) {
                            const texts = [];
                            events.forEach(ev => {
                                const title = ev.querySelector('.font-semibold')?.innerText || '';
                                const details = ev.innerText.replace(title, '').trim();
                                texts.push(`${title}: ${details}`);
                            });
                            content = texts.join('; ');
                        } else {
                            content = '—';
                        }
                        rowData.push(`"${content.replace(/"/g, '""')}"`);
                    });
                    csv += rowData.join(',') + '\n';
                });
                csv += '\n';
            });
            const blob = new Blob([csv], { type: 'text/csv' });
            const a = document.createElement('a');
            a.href = URL.createObjectURL(blob);
            a.download = `teacher_<%= teacher.replace(/[^a-z0-9]/gi, '_') %>_timetable.csv`;
            a.click();
            URL.revokeObjectURL(a.href);
        });
    </script>
</body>
</html>