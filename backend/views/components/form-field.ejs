<!-- Reusable Form Field Component -->
<!-- Usage:
  <%- include('../components/form-field', {
    type: 'email',
    name: 'email',
    id: 'email-field',
    label: 'Email Address',
    placeholder: 'your@email.com',
    required: true,
    value: userEmail,
    error: errorMessage
  }) %>
-->

<div class="mb-4">
    <label for="<%= id %>" class="block text-sm font-semibold text-slate-700 mb-2">
        <%= label %>
        <% if (required) { %>
            <span class="text-red-500">*</span>
        <% } %>
    </label>
    
    <% if (type === 'textarea') { %>
        <textarea
            id="<%= id %>"
            name="<%= name %>"
            placeholder="<%= placeholder || '' %>"
            class="input-field <%= error ? 'border-red-500 focus:ring-red-500' : '' %>"
            <%= required ? 'required' : '' %>
            rows="<%= rows || 4 %>"
        ><%= value || '' %></textarea>
    <% } else if (type === 'select') { %>
        <select
            id="<%= id %>"
            name="<%= name %>"
            class="input-field <%= error ? 'border-red-500 focus:ring-red-500' : '' %>"
            <%= required ? 'required' : '' %>
        >
            <option value="">Select <%= label.toLowerCase() %></option>
            <% if (options && Array.isArray(options)) { %>
                <% options.forEach(opt => { %>
                    <option value="<%= opt.value %>" <%= opt.value === value ? 'selected' : '' %>>
                        <%= opt.label %>
                    </option>
                <% }) %>
            <% } %>
        </select>
    <% } else { %>
        <input
            type="<%= type || 'text' %>"
            id="<%= id %>"
            name="<%= name %>"
            placeholder="<%= placeholder || '' %>"
            value="<%= value || '' %>"
            class="input-field <%= error ? 'border-red-500 focus:ring-red-500' : '' %>"
            <%= required ? 'required' : '' %>
            <%= disabled ? 'disabled' : '' %>
        />
    <% } %>
    
    <% if (error) { %>
        <p class="mt-2 text-xs font-medium text-red-600 flex items-center gap-1">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M18.101 12.93a1 1 0 00-1.414-1.414L10 14.586l-6.687-6.687a1 1 0 00-1.414 1.414l8.1 8.1a1 1 0 001.414 0l10.1-10.1z" clip-rule="evenodd" />
            </svg>
            <%= error %>
        </p>
    <% } %>
    
    <% if (hint) { %>
        <p class="mt-1 text-xs text-slate-500">
            <%= hint %>
        </p>
    <% } %>
</div>
