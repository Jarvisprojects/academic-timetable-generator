<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Error - Timetable Scheduler</title>
    <script src="https://cdn.tailwindcss.com"></script>
  </head>
  <body class="bg-gray-50 min-h-screen flex flex-col">
    <nav class="bg-white border-b border-gray-200 p-4">
      <div class="container mx-auto flex justify-between items-center">
        <a href="/" class="text-xl font-bold text-gray-900">Scheduler</a>
        <div class="flex items-center gap-4">
          <span class="text-gray-500 text-sm" id="username"></span>
          <button type="button" onclick="event.preventDefault(); logout();" class="text-sm text-gray-400 hover:text-gray-600 transition">
            Logout
          </button>
        </div>
      </div>
    </nav>

    <main class="flex-grow flex items-center justify-center p-6 text-center">
      <div class="bg-white p-10 rounded-2xl shadow-sm border border-gray-200 max-w-md w-full">
        <div class="mb-6 inline-flex items-center justify-center w-16 h-16 bg-red-50 rounded-full">
          <svg class="w-8 h-8 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
          </svg>
        </div>

        <h1 class="text-xl font-bold text-gray-900 mb-2">
          Generation Failed
        </h1>
        
        <div class="bg-red-50 border border-red-100 rounded-lg p-4 mb-8">
            <p id="error" class="text-red-700 text-sm font-medium leading-relaxed italic"></p>
        </div>

        <a
          href="/dashboard"
          class="inline-block w-full bg-gray-900 text-white font-semibold px-6 py-3 rounded-xl hover:bg-gray-800 transition-all active:scale-95"
          >Return to Dashboard</a
        >
      </div>
    </main>

    <script src="/js/api.js"></script>
    <script>
      (async () => {
        try {
          await checkAuth();
          const urlParams = new URLSearchParams(window.location.search);
          const id = urlParams.get("id");
          if (!id) window.location.href = "/dashboard";
          
          const timetable = await apiFetch(`/api/timetables/${id}`);
          document.getElementById("error").textContent =
            timetable.error_message || "A system error occurred during optimization.";
        } catch (e) {
          document.getElementById("error").textContent = "Unable to load error details.";
        }
      })();
    </script>
  </body>
</html>