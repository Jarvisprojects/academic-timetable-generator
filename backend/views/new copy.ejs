<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>New Timetable – Timetable Scheduler</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <style>
      body {
        font-family: "Plus Jakarta Sans", sans-serif;
        letter-spacing: -0.01em;
      }
      .section-card {
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      }
      .section-card:hover {
        border-color: #cbd5e1;
        box-shadow: 0 12px 20px -5px rgba(0, 0, 0, 0.05);
      }
      .section-header {
        cursor: pointer;
        user-select: none;
      }
      .section-content {
        max-height: 0;
        overflow: hidden;
        transition: max-height 0.4s cubic-bezier(0, 1, 0, 1);
      }
      .section-content.open {
        max-height: 5000px;
        transition: max-height 0.8s ease-in;
      }
      .rotate-180 {
        transform: rotate(180deg);
      }
      .glass-panel {
        background: rgba(255, 255, 255, 0.8);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border: 1px solid rgba(255, 255, 255, 0.5);
      }
      input, textarea, select {
        transition: border-color 0.2s, box-shadow 0.2s;
      }
      input:focus, textarea:focus, select:focus {
        background-color: #fff !important;
        border-color: #3b82f6 !important;
        box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.1) !important;
        outline: none;
      }
      .error-inline, .warning-inline {
        font-size: 0.75rem;
        margin-top: 0.25rem;
      }
      .action-bar {
        position: sticky;
        bottom: 1rem;
        z-index: 30;
        background: white;
        border-radius: 2rem;
        box-shadow: 0 20px 25px -5px rgba(0,0,0,0.1);
        padding: 0.75rem 1.5rem;
        margin-top: 2rem;
      }
      @media (max-width: 640px) {
        .action-bar {
          padding: 0.5rem 1rem;
        }
      }
    </style>
  </head>
  <body class="bg-[#f9fafb] text-slate-900 antialiased">
    <nav class="bg-white/80 backdrop-blur-md border-b border-slate-200 shadow-sm sticky top-0 z-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between items-center h-16">
          <a href="/" class="flex items-center gap-3 group">
            <div class="w-10 h-10 bg-blue-600 rounded-xl flex items-center justify-center shadow-lg shadow-blue-200 group-hover:rotate-6 transition-transform">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
            </div>
            <div>
              <p class="text-base font-bold text-slate-900 leading-tight tracking-tight">Timetable Scheduler</p>
              <p class="text-[10px] font-bold text-blue-600 uppercase tracking-widest">v2.0 Stable</p>
            </div>
          </a>
          <div class="flex items-center gap-4">
            <span id="username" class="text-sm font-semibold text-slate-500 hidden sm:inline-block"></span>
            <button onclick="logout()" class="px-4 py-2 text-xs font-bold text-red-500 hover:bg-red-50 rounded-lg transition-colors border border-transparent hover:border-red-100 uppercase tracking-tighter">Sign Out</button>
          </div>
        </div>
      </div>
    </nav>

    <main class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <div class="mb-10 text-center sm:text-left">
        <h1 class="text-4xl font-extrabold text-slate-900 tracking-tight" id="page-title">Create New Timetable</h1>
        <p class="text-slate-500 mt-2 text-lg">Set your constraints and generate an optimized schedule in seconds.</p>
      </div>

      <!-- Error Summary Panel (live) -->
      <div id="error-summary" class="hidden bg-red-50 border border-red-200 text-red-700 p-4 rounded-xl shadow-sm mb-8"></div>

      <div id="error" class="bg-red-50 border border-red-200 text-red-700 p-4 rounded-xl shadow-sm mb-8 hidden flex items-center gap-3">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd" /></svg>
        <span class="font-bold">Check your inputs!</span>
      </div>
      <div id="success" class="hidden bg-green-100 text-green-800 p-3 rounded-lg mb-4"></div>

      <form id="timetable-form" class="space-y-8">
        <div class="glass-panel rounded-2xl shadow-xl shadow-slate-200/50 p-2 flex flex-wrap gap-4 items-center justify-between sticky top-20 z-40 border border-slate-200/60">
          <div class="flex gap-1 p-1 bg-slate-100/80 rounded-xl">
            <label class="flex items-center px-5 py-2 rounded-lg cursor-pointer transition-all has-[:checked]:bg-white has-[:checked]:text-blue-600 has-[:checked]:shadow-sm text-slate-500 font-bold text-sm">
              <input type="radio" name="input_mode" value="form" checked class="hidden" /> Form Mode
            </label>
            <label class="flex items-center px-5 py-2 rounded-lg cursor-pointer transition-all has-[:checked]:bg-white has-[:checked]:text-blue-600 has-[:checked]:shadow-sm text-slate-500 font-bold text-sm">
              <input type="radio" name="input_mode" value="json" class="hidden" /> JSON Mode
            </label>
          </div>
          <div class="flex items-center gap-3">
            <button type="button" id="save-draft-btn" class="px-4 py-2 text-xs font-bold text-slate-600 bg-white border border-slate-200 rounded-xl hover:bg-slate-50 transition-all shadow-sm">💾 Save Draft</button>
            <button type="button" id="clear-draft-btn" class="px-4 py-2 text-xs font-bold text-red-600 bg-white border border-red-200 rounded-xl hover:bg-red-50 transition-all shadow-sm">🗑️ Clear Draft</button>
            <button type="button" id="reset-form-btn" class="px-4 py-2 text-xs font-bold text-blue-600 bg-white border border-blue-200 rounded-xl hover:bg-blue-50 transition-all shadow-sm">🔄 Reset Form</button>
            <button type="button" id="load-sample-json" class="text-xs font-bold text-slate-400 hover:text-blue-600 transition-colors px-3 py-2">Load Template</button>
            <button type="button" id="copy-to-json" class="bg-blue-50 hover:bg-blue-100 text-blue-600 px-5 py-2.5 rounded-xl font-bold text-xs transition-all border border-blue-100">Copy Form as JSON</button>
          </div>
        </div>

        <div id="form-container" class="space-y-6">
          <!-- Basic Info -->
          <div class="section-card bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
            <div class="section-header px-8 py-5 bg-slate-50/50 flex justify-between items-center group">
              <h2 class="text-lg font-bold text-slate-800 flex items-center gap-3"><span class="w-8 h-8 rounded-lg bg-blue-100 text-blue-600 flex items-center justify-center">📋</span>Basic Information</h2>
              <svg class="w-5 h-5 text-slate-400 transition-transform group-hover:text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
            </div>
            <div class="section-content open p-8">
              <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <div><label class="block text-slate-500 font-bold mb-2 text-[10px] uppercase tracking-widest">Timetable Name *</label><input type="text" name="name" placeholder="Computer Science - Year 3" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3" /></div>
                <div><label class="block text-slate-500 font-bold mb-2 text-[10px] uppercase tracking-widest">Description</label><textarea name="description" rows="1" placeholder="Optional notes..." class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3"></textarea></div>
              </div>
            </div>
          </div>

          <!-- Time Settings -->
          <div class="section-card bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
            <div class="section-header px-8 py-5 bg-slate-50/50 flex justify-between items-center group">
              <h2 class="text-lg font-bold text-slate-800 flex items-center gap-3"><span class="w-8 h-8 rounded-lg bg-indigo-100 text-indigo-600 flex items-center justify-center">⏰</span>Time Settings</h2>
              <svg class="w-5 h-5 text-slate-400 transition-transform group-hover:text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
            </div>
            <div class="section-content open p-8">
              <div class="grid grid-cols-2 md:grid-cols-2 gap-6 mb-10">
                <div class="p-4 bg-slate-50 rounded-2xl border border-slate-100"><label class="block font-bold text-[10px] text-slate-400 uppercase tracking-widest mb-1">Days / Week</label><input type="number" name="days" min="1" max="7" value="5" class="w-full bg-transparent text-xl font-bold p-0 border-none focus:ring-0" /></div>
                <div class="p-4 bg-slate-50 rounded-2xl border border-slate-100"><label class="block font-bold text-[10px] text-slate-400 uppercase tracking-widest mb-1">Slot Duration (Min)</label><input type="number" name="slot_duration" min="5" max="120" step="5" value="60" class="w-full bg-transparent text-xl font-bold p-0 border-none focus:ring-0" /></div>
              </div>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-12 pt-8 border-t border-slate-100">
                <div><p class="font-bold text-sm text-slate-800 mb-4 flex items-center gap-2">Start Time</p><div class="flex gap-2"><input type="number" class="start-hour w-20 bg-slate-50 border border-slate-200 rounded-xl px-2 py-3 text-center font-bold" min="1" max="12" value="9" /><input type="number" class="start-minute w-20 bg-slate-50 border border-slate-200 rounded-xl px-2 py-3 text-center font-bold" min="0" max="59" value="0" /><select class="start-ampm bg-slate-100 border-none rounded-xl px-4 py-3 font-bold"><option value="AM">AM</option><option value="PM">PM</option></select></div></div>
                <div><p class="font-bold text-sm text-slate-800 mb-4 flex items-center gap-2">End Time</p><div class="flex gap-2"><input type="number" class="end-hour w-20 bg-slate-50 border border-slate-200 rounded-xl px-2 py-3 text-center font-bold" min="1" max="12" value="5" /><input type="number" class="end-minute w-20 bg-slate-50 border border-slate-200 rounded-xl px-2 py-3 text-center font-bold" min="0" max="59" value="0" /><select class="end-ampm bg-slate-100 border-none rounded-xl px-4 py-3 font-bold"><option value="AM">AM</option><option value="PM" selected>PM</option></select></div></div>
              </div>
            </div>
          </div>

          <!-- Years & Batches -->
          <div class="section-card bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
            <div class="section-header px-8 py-5 bg-slate-50/50 flex justify-between items-center group">
              <h2 class="text-lg font-bold text-slate-800 flex items-center gap-3"><span class="w-8 h-8 rounded-lg bg-emerald-100 text-emerald-600 flex items-center justify-center">🎓</span>Years & Batches</h2>
              <svg class="w-5 h-5 text-slate-400 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
            </div>
            <div class="section-content open p-8"><div id="years-container" class="space-y-4"></div><button type="button" id="add-year" class="mt-4 flex items-center gap-2 text-sm font-bold text-emerald-600 bg-emerald-50 px-6 py-3 rounded-xl hover:bg-emerald-600 hover:text-white transition-all">+ Add Year</button></div>
          </div>

          <!-- Teachers -->
          <div class="section-card bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
            <div class="section-header px-8 py-5 bg-slate-50/50 flex justify-between items-center group">
              <h2 class="text-lg font-bold text-slate-800 flex items-center gap-3"><span class="w-8 h-8 rounded-lg bg-orange-100 text-orange-600 flex items-center justify-center">👩‍🏫</span>Teachers</h2>
              <svg class="w-5 h-5 text-slate-400 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
            </div>
            <div class="section-content open p-8"><div id="teachers-container" class="space-y-4"></div><button type="button" id="add-teacher" class="mt-4 flex items-center gap-2 text-sm font-bold text-orange-600 bg-orange-50 px-6 py-3 rounded-xl hover:bg-orange-600 hover:text-white transition-all">+ Add Teacher</button></div>
          </div>

          <!-- Labs -->
          <div class="section-card bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
            <div class="section-header px-8 py-5 bg-slate-50/50 flex justify-between items-center group">
              <h2 class="text-lg font-bold text-slate-800 flex items-center gap-3"><span class="w-8 h-8 rounded-lg bg-purple-100 text-purple-600 flex items-center justify-center">🧪</span>Labs</h2>
              <svg class="w-5 h-5 text-slate-400 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
            </div>
            <div class="section-content open p-8"><div id="labs-container" class="space-y-3"></div><button type="button" id="add-lab" class="mt-4 flex items-center gap-2 text-sm font-bold text-purple-600 bg-purple-50 px-6 py-3 rounded-xl hover:bg-purple-600 hover:text-white transition-all">+ Add Lab</button></div>
          </div>

          <!-- Rooms -->
          <div class="section-card bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
            <div class="section-header px-8 py-5 bg-slate-50/50 flex justify-between items-center group">
              <h2 class="text-lg font-bold text-slate-800 flex items-center gap-3"><span class="w-8 h-8 rounded-lg bg-yellow-100 text-yellow-600 flex items-center justify-center">🏢</span>Rooms</h2>
              <svg class="w-5 h-5 text-slate-400 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
            </div>
            <div class="section-content open p-8"><div id="rooms-container" class="space-y-3"></div><button type="button" id="add-room" class="mt-4 flex items-center gap-2 text-sm font-bold text-yellow-600 bg-yellow-50 px-6 py-3 rounded-xl hover:bg-yellow-600 hover:text-white transition-all">+ Add Room</button></div>
          </div>

          <!-- Subjects -->
          <div class="section-card bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
            <div class="section-header px-8 py-5 bg-slate-50/50 flex justify-between items-center group">
              <h2 class="text-lg font-bold text-slate-800 flex items-center gap-3"><span class="w-8 h-8 rounded-lg bg-pink-100 text-pink-600 flex items-center justify-center">📚</span>Subjects</h2>
              <svg class="w-5 h-5 text-slate-400 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
            </div>
            <div class="section-content open p-8"><div id="subjects-container" class="space-y-4"></div><button type="button" id="add-subject" class="mt-4 flex items-center gap-2 text-sm font-bold text-pink-600 bg-pink-50 px-6 py-3 rounded-xl hover:bg-pink-600 hover:text-white transition-all">+ Add Subject</button></div>
          </div>

          <!-- Breaks -->
          <div class="section-card bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
            <div class="section-header px-8 py-5 bg-slate-50/50 flex justify-between items-center group">
              <h2 class="text-lg font-bold text-slate-800 flex items-center gap-3"><span class="w-8 h-8 rounded-lg bg-cyan-100 text-cyan-600 flex items-center justify-center">☕</span>Breaks</h2>
              <svg class="w-5 h-5 text-slate-400 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
            </div>
            <div class="section-content open p-8"><div id="breaks-container" class="space-y-4"></div><button type="button" id="add-break-card" class="mt-4 flex items-center gap-2 text-sm font-bold text-cyan-600 bg-cyan-50 px-6 py-3 rounded-xl hover:bg-cyan-600 hover:text-white transition-all">+ Add Break Set</button></div>
          </div>

          <!-- Unavailability -->
          <div class="section-card bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
            <div class="section-header px-8 py-5 bg-slate-50/50 flex justify-between items-center group">
              <h2 class="text-lg font-bold text-slate-800 flex items-center gap-3"><span class="w-8 h-8 rounded-lg bg-red-100 text-red-600 flex items-center justify-center">🚫</span>Unavailability</h2>
              <svg class="w-5 h-5 text-slate-400 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
            </div>
            <div class="section-content open p-8">
              <div class="mb-12"><h3 class="font-bold text-slate-400 text-[10px] uppercase tracking-[0.2em] mb-4">Faculty Downtime</h3><div id="teacher-unavail-container" class="space-y-3"></div><button type="button" id="add-teacher-unavail" class="mt-4 text-xs font-bold text-blue-600 bg-blue-50 px-4 py-2 rounded-lg hover:bg-blue-600 hover:text-white transition-all">+ Add Teacher Constraint</button></div>
              <div class="pt-8 border-t border-slate-100"><h3 class="font-bold text-slate-400 text-[10px] uppercase tracking-[0.2em] mb-4">Laboratory Downtime</h3><div id="lab-unavail-container" class="space-y-3"></div><button type="button" id="add-lab-unavail" class="mt-4 text-xs font-bold text-blue-600 bg-blue-50 px-4 py-2 rounded-lg hover:bg-blue-600 hover:text-white transition-all">+ Add Lab Constraint</button></div>
            </div>
          </div>
        </div>

        <div id="json-container" class="hidden">
          <div class="bg-slate-800 rounded-3xl shadow-2xl p-6 border border-slate-700">
            <div class="flex items-center justify-between mb-4"><span class="text-xs font-bold text-slate-400 uppercase tracking-widest">Configuration Editor</span><span class="px-2 py-1 bg-slate-700 text-emerald-400 text-[10px] rounded font-mono">JSON Ready</span></div>
            <textarea id="json-input" rows="20" class="w-full bg-slate-900 text-blue-300 border border-slate-700 rounded-2xl px-5 py-4 font-mono text-sm leading-relaxed focus:ring-2 focus:ring-blue-500/30" placeholder="// Paste your JSON here..."></textarea>
          </div>
        </div>

        <!-- Sticky Action Bar -->
        <div class="action-bar flex flex-col sm:flex-row justify-end items-center gap-6 border-t border-slate-200">
          <button type="button" id="preview-btn" class="px-8 py-4 rounded-2xl font-bold text-slate-600 bg-white border border-slate-200 hover:bg-slate-50 transition-all active:scale-95 shadow-sm">Preview Data</button>
          <button type="submit" id="submit-btn" class="bg-blue-600 text-white px-12 py-4 rounded-2xl font-extrabold hover:bg-blue-700 transition-all active:scale-95 shadow-xl shadow-blue-200 flex items-center justify-center gap-2">Generate Schedule<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg></button>
        </div>
      </form>
    </main>

    <script src="/js/api.js"></script>
    <script src="/js/utils.js"></script>
    <script src="/js/handlers.js"></script>
    <script src="/js/form-builder.js"></script>
    <script src="/js/populate.js"></script>
    <script src="/js/sync.js"></script>
    <script src="/js/draft.js"></script>
    <script src="/js/new.js"></script>
  </body>
</html>