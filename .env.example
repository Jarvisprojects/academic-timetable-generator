# ========== SERVER CONFIGURATION ==========
# Port to run the application on
PORT=3000

# ========== DATABASE CONFIGURATION ==========
# PostgreSQL connection string
# Format: postgresql://username:password@host:port/database
# Example: postgresql://timetable_user:mypassword@localhost:5432/timetable_db
DATABASE_URL=postgresql://timetable_user:your_password@localhost:5432/timetable_db

# ========== SECURITY ==========
# JWT secret key for token signing (change this to a random string in production!)
# Generate using:
#   Linux/macOS: openssl rand -hex 32
#   Windows: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_very_secret_jwt_key_change_this_in_production

# ========== PYTHON & SCHEDULER ==========
# Path to Python executable in the venv
# The system will auto-detect, but you can set it manually:
#
# Linux/macOS:
#   ./venv/bin/python
#   /usr/bin/python3
#
# Windows:
#   venv\Scripts\python.exe
#   C:\Python39\python.exe
#
# Leave as-is below for auto-detection:
PYTHON_PATH=./venv/bin/python

# ========== ENVIRONMENT ==========
# Set to 'development' for detailed logs or 'production' for optimized performance
NODE_ENV=development
